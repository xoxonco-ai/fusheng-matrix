# ---- Backend (FastAPI) — all settings use the VA_ prefix ----

# Delete uploaded/converted audio right after analysis (default false = delete).
# Set true only for local debugging.
VA_KEEP_AUDIO=false

# Below this recording-quality confidence (0-100) the API refuses to
# produce wuxing scores instead of inventing a conclusion.
VA_MIN_CONFIDENCE=40

# Upload limits
VA_MAX_UPLOAD_BYTES=26214400
VA_MIN_DURATION_SEC=3
VA_MAX_DURATION_SEC=120

# Comma-separated allowed CORS origins for direct API access
VA_CORS_ORIGINS=http://localhost:3000

# ---- Frontend (Next.js) ----
# Where the frontend server proxies /api/* to
API_BASE=http://localhost:8000
